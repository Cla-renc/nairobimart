{
  "buildCommand": "npm install && npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/flash-sale-automation",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/abandoned-cart",
      "schedule": "0 10 * * *"
    }
  ]
}
